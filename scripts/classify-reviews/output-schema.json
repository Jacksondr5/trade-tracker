{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "classifications": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "comment_id": {
            "type": "string",
            "description": "The unique identifier for this comment"
          },
          "category": {
            "type": "string",
            "enum": [
              "bug",
              "performance",
              "design-system",
              "accessibility",
              "convention",
              "test-quality",
              "data-integrity",
              "ux-behavior",
              "pre-existing",
              "informational",
              "self-resolution",
              "meta"
            ],
            "description": "The primary category of feedback"
          },
          "correctness": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5,
            "description": "Is the feedback factually accurate? 1=wrong, 5=completely correct"
          },
          "actionability": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5,
            "description": "Can the developer act on it? 1=vague/no action, 5=specific fix provided"
          },
          "severity": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5,
            "description": "How important is the issue? 1=trivial, 5=critical bug/security"
          },
          "reasoning": {
            "type": "string",
            "description": "Brief explanation for the classification and scores"
          }
        },
        "required": [
          "comment_id",
          "category",
          "correctness",
          "actionability",
          "severity",
          "reasoning"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": ["classifications"],
  "additionalProperties": false
}
