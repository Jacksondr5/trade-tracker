# App runtime
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
NEXT_PUBLIC_CLERK_FRONTEND_API_URL=https://your-clerk-frontend-api-url
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
VERCEL_GATEWAY_API_KEY=your_vercel_gateway_api_key

# Bravos / Browserbase ingestion
# Set to true only in the production Convex deployment.
BRAVOS_SCHEDULED_SCANS_ENABLED=false
BRAVOS_WORKER_SECRET=replace-with-a-long-random-shared-secret
# Next.js worker route URL for Convex dispatch, for example:
# BRAVOS_WORKER_URL=http://127.0.0.1:3000/api/internal/bravos/run
BRAVOS_WORKER_URL=https://your-app.example.com/api/internal/bravos/run
BROWSERBASE_API_KEY=bb_live_your_browserbase_api_key
BROWSERBASE_PROJECT_ID=your_browserbase_project_id

# Playwright / Codex local UI testing
PLAYWRIGHT_PASSWORD=your-playwright-test-password
PLAYWRIGHT_OWNER_ID=your-clerk-token-identifier-for-the-playwright-user
PLAYWRIGHT_USERNAME=your-playwright-test-user@example.com
VERCEL_AUTOMATION_BYPASS_SECRET=your-vercel-automation-bypass-secret

# Optional
# SKIP_ENV_VALIDATION=false
